# Archivo de variables de entorno para Docker Compose (Business System Frontend)
# Copia este archivo como '.env' en esta misma carpeta y define tus valores reales antes de hacer deploy.

# URL de la API del backend accesible por el navegador del usuario final.
# IMPORTANTE: Si vas a usar un dominio real, debes colocar la URL pública de la API aquí antes de hacer 'docker-compose up --build'.
VITE_API_URL=http://localhost:5000/api

# Credenciales y endpoints de Supabase para la carga y lectura de imágenes de productos.
VITE_SUPABASE_URL=https://tu-proyecto.supabase.co
VITE_SUPABASE_ANON_KEY=tu-clave-anon-de-supabase

# FRONTEND_PORT=5173
